msgstr "Մուտքագրեք վավեր արժեք։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:70
msgid "Enter a valid domain name."
msgstr "Մուտքագրեք վավեր դոմեյնի անուն։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:153
#: djvenv/lib/python3.13/site-packages/django/forms/fields.py:773
msgid "Enter a valid URL."
msgstr "Մուտքագրեք վավեր URL։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:200
msgid "Enter a valid integer."
msgstr "Մուտքագրեք վավեր ամբողջ թիվ։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:211
msgid "Enter a valid email address."
msgstr "Մուտքագրեք վավեր էլեկտրոնային հասցե։"

#. Translators: "letters" means latin letters: a-z and A-Z.
#: djvenv/lib/python3.13/site-packages/django/core/validators.py:289
msgid ""
"Enter a valid “slug” consisting of letters, numbers, underscores or hyphens."
msgstr ""
"Մուտքագրեք վավեր «slug»՝ բաղկացած տառերից, թվերից, ընդգծման նշաններից կամ "
"գծիկներից։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:297
msgid ""
"Enter a valid “slug” consisting of Unicode letters, numbers, underscores, or "
"hyphens."
msgstr ""
"Մուտքագրեք վավեր «slug»՝ կազմված Unicode տառերից, թվերից, ընդգծման նշաններից "
"կամ գծիկներից։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:309
#: djvenv/lib/python3.13/site-packages/django/core/validators.py:318
#: djvenv/lib/python3.13/site-packages/django/core/validators.py:332
#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:2220
#, python-format
msgid "Enter a valid %(protocol)s address."
msgstr "Մուտքագրեք վավեր %(protocol)s հասցե։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:311
msgid "IPv4"
msgstr "IPv4"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:320
#: djvenv/lib/python3.13/site-packages/django/utils/ipv6.py:43
msgid "IPv6"
msgstr "IPv6"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:334
msgid "IPv4 or IPv6"
msgstr "IPv4 կամ IPv6"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:375
msgid "Enter only digits separated by commas."
msgstr "Մուտքագրեք միայն ստորակետերով բաժանված թվանշաններ։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:381
#, python-format
msgid "Ensure this value is %(limit_value)s (it is %(show_value)s)."
msgstr "Համոզվեք, որ այս արժեքը %(limit_value)s է (այն %(show_value)s է)։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:416
#, python-format
msgid "Ensure this value is less than or equal to %(limit_value)s."
msgstr "Համոզվեք, որ այս արժեքը փոքր կամ հավասար է %(limit_value)s-ին։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:425
#, python-format
msgid "Ensure this value is greater than or equal to %(limit_value)s."
msgstr "Համոզվեք, որ այս արժեքը մեծ է կամ հավասար %(limit_value)s-ին։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:434
#, python-format
msgid "Ensure this value is a multiple of step size %(limit_value)s."
msgstr "Համոզվեք, որ այս արժեքը %(limit_value)s քայլի չափի բազմապատիկն է։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:441
#, python-format
msgid ""
"Ensure this value is a multiple of step size %(limit_value)s, starting from "
"%(offset)s, e.g. %(offset)s, %(valid_value1)s, %(valid_value2)s, and so on."
msgstr ""
"Համոզվեք, որ այս արժեքը %(limit_value)s քայլի չափի բազմապատիկն է՝ սկսած "
"%(offset)s-ից, օրինակ՝ %(offset)s, %(valid_value1)s, %(valid_value2)s և այլն։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:473
#, python-format
msgid ""
"Ensure this value has at least %(limit_value)d character (it has "
"%(show_value)d)."
msgid_plural ""
"Ensure this value has at least %(limit_value)d characters (it has "
"%(show_value)d)."
msgstr[0] ""
"Համոզվեք, որ այս արժեքը պարունակում է առնվազն %(limit_value)d նիշ (այն ունի "
"%(show_value)d):"
msgstr[1] ""
"Համոզվեք, որ այս արժեքը պարունակում է առնվազն %(limit_value)d նիշ (այն ունի "
"%(show_value)d):"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:491
#, python-format
msgid ""
"Ensure this value has at most %(limit_value)d character (it has "
"%(show_value)d)."
msgid_plural ""
"Ensure this value has at most %(limit_value)d characters (it has "
"%(show_value)d)."
msgstr[0] ""
"Համոզվեք, որ այս արժեքը պարունակում է առավելագույնը %(limit_value)d նիշ (այն "
"ունի %(show_value)d):"
msgstr[1] ""
"Համոզվեք, որ այս արժեքը պարունակում է առավելագույնը %(limit_value)d նիշ (այն "
"ունի %(show_value)d):"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:514
#: djvenv/lib/python3.13/site-packages/django/forms/fields.py:364
#: djvenv/lib/python3.13/site-packages/django/forms/fields.py:403
msgid "Enter a number."
msgstr "Մուտքագրեք թիվ։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:516
#, python-format
msgid "Ensure that there are no more than %(max)s digit in total."
msgid_plural "Ensure that there are no more than %(max)s digits in total."
msgstr[0] "Համոզվեք, որ ընդհանուր թվանշանների քանակը չի գերազանցում %(max)s-ը։"
msgstr[1] "Համոզվեք, որ ընդհանուր թվանշանների քանակը չի գերազանցում %(max)s-ը։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:521
#, python-format
msgid "Ensure that there are no more than %(max)s decimal place."
msgid_plural "Ensure that there are no more than %(max)s decimal places."
msgstr[0] "Համոզվեք, որ տասնորդական նիշերի քանակը չի գերազանցում %(max)s-ը։"
msgstr[1] "Համոզվեք, որ տասնորդական նիշերի քանակը չի գերազանցում %(max)s-ը։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:526
#, python-format
msgid ""
"Ensure that there are no more than %(max)s digit before the decimal point."
msgid_plural ""
"Ensure that there are no more than %(max)s digits before the decimal point."
msgstr[0] "Համոզվեք, որ տասնորդական կետից առաջ չկա %(max)s-ից ավելի թվանշան։"
msgstr[1] "Համոզվեք, որ տասնորդական կետից առաջ չկա %(max)s-ից ավելի թվանշան։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:597
#, python-format
msgid ""
"File extension “%(extension)s” is not allowed. Allowed extensions are: "
"%(allowed_extensions)s."
msgstr ""
"«%(extension)s» ֆայլի ընդլայնումը թույլատրված չէ։ Թույլատրված ընդլայնումներն "
"են՝ %(allowed_extensions)s։"

#: djvenv/lib/python3.13/site-packages/django/core/validators.py:659
msgid "Null characters are not allowed."
msgstr "Զրոյական նիշերը թույլատրված չեն։"

#: djvenv/lib/python3.13/site-packages/django/db/models/base.py:1633
#: djvenv/lib/python3.13/site-packages/django/forms/models.py:932
msgid "and"
msgstr "և"

#: djvenv/lib/python3.13/site-packages/django/db/models/base.py:1635
#, python-format
msgid "%(model_name)s with this %(field_labels)s already exists."
msgstr "Այս %(field_labels)s-ով %(model_name)s արդեն գոյություն ունի։"

#: djvenv/lib/python3.13/site-packages/django/db/models/constraints.py:20
#, python-format
msgid "Constraint “%(name)s” is violated."
msgstr "«%(name)s» սահմանափակումը խախտված է։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:134
#, python-format
msgid "Value %(value)r is not a valid choice."
