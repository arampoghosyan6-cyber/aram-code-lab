#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:135
msgid "This field cannot be null."
msgstr "Այս դաշտը չի կարող դատարկ լինել։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:136
msgid "This field cannot be blank."
msgstr "Այս դաշտը չի կարող դատարկ լինել։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:137
#, python-format
msgid "%(model_name)s with this %(field_label)s already exists."
msgstr "Այս %(field_label)s-ով %(model_name)s-ը արդեն գոյություն ունի։"

#. Translators: The 'lookup_type' is one of 'date', 'year' or
#. 'month'. Eg: "Title must be unique for pub_date year"
#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:141
#, python-format
msgid ""
"%(field_label)s must be unique for %(date_field_label)s %(lookup_type)s."
msgstr ""
"%(field_label)s-ը պետք է եզակի լինի %(date_field_label)s %(lookup_type)s-ի "
"համար։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:180
#, python-format
msgid "Field of type: %(field_type)s"
msgstr "Տեսակի դաշտ՝ %(field_type)s"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1161
#, python-format
msgid "“%(value)s” value must be either True or False."
msgstr "«%(value)s» արժեքը պետք է լինի True կամ False։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1162
#, python-format
msgid "“%(value)s” value must be either True, False, or None."
msgstr "«%(value)s» արժեքը պետք է լինի True, False կամ None։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1164
msgid "Boolean (Either True or False)"
msgstr "Բուլյան (ճիշտ է կամ սխալ)"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1214
#, python-format
msgid "String (up to %(max_length)s)"
msgstr "Տող (մինչև %(max_length)s)"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1216
msgid "String (unlimited)"
msgstr "Տող (անսահմանափակ)"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1325
msgid "Comma-separated integers"
msgstr "Ստորակետերով բաժանված ամբողջ թվեր"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1426
#, python-format
msgid ""
"“%(value)s” value has an invalid date format. It must be in YYYY-MM-DD "
"format."
msgstr ""
"«%(value)s» արժեքն ունի անվավեր ամսաթվի ձևաչափ։ Այն պետք է լինի YYYY-MM-DD "
"ձևաչափով։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1430
#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1565
#, python-format
msgid ""
"“%(value)s” value has the correct format (YYYY-MM-DD) but it is an invalid "
"date."
msgstr ""
"«%(value)s» արժեքը ունի ճիշտ ձևաչափ (YYYY-MM-DD), բայց այն անվավեր ամսաթիվ է։"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1434
msgid "Date (without time)"
msgstr "Ամսաթիվ (առանց ժամանակի)"

#: djvenv/lib/python3.13/site-packages/django/db/models/fields/__init__.py:1561
#, python-format
msgid ""
"“%(value)s” value has an invalid format. It must be in YYYY-MM-DD "
